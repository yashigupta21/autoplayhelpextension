{
  "manifest_version": 3,
  "name": "Netflix AutoSkip",
  "version": "1.0.0",
  "description": "Automatically clicks 'Skip Intro' and 'Next Episode' on Netflix.",
  "permissions": [],
  "host_permissions": [
    "*://*.netflix.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.netflix.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Netflix AutoSkip"
  }
}
